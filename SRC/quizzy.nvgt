void main_menu() {
	load_menu_music();
	menu m;
	m.add_item("Start Game", "start");
	m.add_item("Download Category for Offline", "download");
	m.add_item("Manage Custom Packs", "manage_custom");
	m.add_item("Statistics", "stats");
	m.add_item("Settings", "settings");
	m.add_item("Credits", "credits");
	m.add_item("Exit", "exit");
	m.intro_text = "Welcome to quizzy! Select an option.";
	m.click_sound = "item_move.mp3";
	m.select_sound = "click.mp3";
	m.open_sound = "window_open.mp3";
	m.close_sound = "window_close.mp3";
	m.edge_sound = "item_move.mp3";
	m.wrap_sound = "item_move.mp3";
	m.focus_first_item = true;
	int master_vol = int(config.read_number("master_volume", 100));
	while (true) {
		m.wrap = (config.read_string("menu_wrap", "false") == "true");
		wait(5);
		touch_manager.monitor();
		gm.prepare_frame();
		gm.draw_menu(m);
		gm.present_frame();
		if (key_pressed(KEY_PAGEUP)) {
			master_vol += 5;
			if (master_vol > 100) master_vol = 100;
			float db = (master_vol == 0 ? -100.0 : 20.0 * log10(float(master_vol) / 100.0));
			set_sound_master_volume(db);
			config.write_number("master_volume", master_vol);
			speak("Volume " + master_vol, false);
		}
		if (key_pressed(KEY_PAGEDOWN)) {
			master_vol -= 5;
			if (master_vol < 0) master_vol = 0;
			float db = (master_vol == 0 ? -100.0 : 20.0 * log10(float(master_vol) / 100.0));
			set_sound_master_volume(db);
			config.write_number("master_volume", master_vol);
			speak("Volume " + master_vol, false);
		}
		if (key_pressed(KEY_F12)) {
			string token = input_box("GitHub Token", "Paste your GitHub Personal Access Token here to enable updates for private repositories:");
			if (token != "") {
				file_put_contents("github_token.txt", token);
				speak("Token saved.", false);
				check_for_updates(false);
			}
		}
		if (!m.monitor()) {
			string choice = m.selected_item_id;
			if (choice == "start") {
				while (true) {
					string lang = select_language();
					if (lang == "back") break;
					int cat_id = select_category();
					if (cat_id == -1) continue; 
					init_questions(lang, cat_id);
					if (questions.length() == 0) {
						alert("Quizzy", "No questions available to start the game.");
					} else {
						state.reset();
						state.current_lang = lang;
						state.category_id = cat_id;
						game_loop();
						load_menu_music();
					}
					break; 
				}
				main_menu_reset(m);
			} else if (choice == "download") {
				string lang = select_language();
				if (lang != "back") {
					int cat_id = select_category();
					if (cat_id != -1) {
						download_category(cat_id, lang);
					}
				}
				main_menu_reset(m);
			} else if (choice == "manage_custom") {
				manage_custom_packs_menu();
				main_menu_reset(m);
			} else if (choice == "stats") {
				stats.show_stats_menu();
			} else if (choice == "settings") {
				settings_menu();
			} else if (choice == "credits") {
				show_credits();
			} else if (choice == "exit" || choice == "") {
				exit();
			}
		}
	}
}

void main_menu_reset(menu@ m) {
	m.reset();
	m.add_item("Start Game", "start");
	m.add_item("Download Category for Offline", "download");
	m.add_item("Manage Custom Packs", "manage_custom");
	m.add_item("Statistics", "stats");
	m.add_item("Settings", "settings");
	m.add_item("Credits", "credits");
	m.add_item("Exit", "exit");
}

string select_custom_pack() {
	string path = get_custom_questions_path();
	string filename = open_file_dialog("Question Packs:json", "");
	return filename;
}

string format_currency(int amount) {
	string s = "" + amount;
	if (s.length() <= 3) return s;
	string res = s.substr(s.length() - 3);
	s = s.substr(0, s.length() - 3);
	while (s.length() > 2) {
		res = s.substr(s.length() - 2) + "," + res;
		s = s.substr(0, s.length() - 2);
	}
	if (s.length() > 0) res = s + "," + res;
	return res;
}

void game_loop() {
	load_menu_music();
	blitz_ready = false;
	blitz_fetching = false;
	blitz_pool.resize(0);
	for (uint i = 0; i < questions.length(); i++) {
		state.current_question_index = i;
		if (!play_question(questions[i], i)) {
			int current_prize = (i > 0) ? parse_int(prizes[i-1].replace(",", "")) : 0;
			stats.record_game(current_prize, state.bonus_money, i, state.lifelines_used_count);
			return;
		}
		if (!state.blitz_played && !blitz_fetching && !blitz_ready && (i >= 6 || state.lifelines_used_count >= 2)) {
			@blitz_fetch_handle = async<void>(init_questions_bg, state.current_lang, 0, 20, true); 
		}
		if (!state.blitz_played && (i == 9 || state.lifelines_used_count >= 4)) {

			string reason = (i == 9) ? "You have reached Question 10." : "You have used 4 or more lifelines.";
			if (ask_yes_no("Quizzy", reason + " Would you like to take the blitz mode? If you don't take it now, you can press F5 while playing the game to take it later when you need it.") == 1) {
				blitz_round();
			}
		}
		if (i < 8) {
			play_sfx("sahiJawab_10-02-26_16-31-59-720.mp3", true);
		} else {
			play_sfx("SahiJawab2_15-02-26_15-12-00-471.mp3", true);
		}
		if (manual_next_question && i < questions.length() - 1) {
			speak("Correct answer. Press enter to continue to the next question.", false);
			while (!key_pressed(KEY_RETURN)) {
				wait(5);
				touch_manager.monitor();
				gm.prepare_frame();
				gm.draw_logo();
				gm.present_frame();
			}
		}
		if (i < questions.length() - 1) {
			if (state.current_lang == "hi") {
				speak("प्रश्न " + (i + 2), false);
			} else {
				speak("Question " + (i + 2), false);
			}
		} else {
			if (state.current_lang == "hi") {
				speak("सही जवाब।", false);
			} else {
				speak("Correct answer.", false);
			}
		}
	}
	safe_stop(bg_music);
	string total_prize_str = prizes[questions.length() - 1];
	int base_prize = parse_int(total_prize_str.replace(",", ""));
	int grand_total = base_prize + state.bonus_money;
	stats.record_game(base_prize, state.bonus_money, questions.length(), state.lifelines_used_count);
	if (state.bonus_money > 0) {
		alert("Quizzy", "Congratulations! You have won the game!\n\nBase Prize: ₹" + total_prize_str + "\nBonus: ₹" + format_currency(state.bonus_money) + "\nGrand Total: ₹" + format_currency(grand_total) + "!");
	} else {
		alert("Quizzy", "Congratulations! You have won the game and earned ₹" + total_prize_str + "!");
	}
}

void safe_stop(sound@ s) {
	if (@s == null) return;
	if (s.active && s.playing) {
		s.stop();
	}
}

bool handle_option_selection(Question@ q, int question_index, int i, int[]& option_buttons, bool& double_dip_active, int& current_selection) {
	play_sfx("click.mp3");
	if (ask_yes_no("Quizzy", "Is this your final answer?") != 1) {
		return false; 
	}
	safe_stop(bg_music);
	if (option_locking_sound_enabled) {
		sound lock_sfx;
		if (load_sound(lock_sfx, "Kbc Option Lock Tune.mp3")) {
			lock_sfx.volume = 0; 
			lock_sfx.play();
			timer wait_timer;
			while (wait_timer.elapsed < 5000) {
				wait(5);
				touch_manager.monitor();
				gm.prepare_frame();
				gm.draw_question(q.question, q.options, current_selection);
				gm.draw_prize_ladder(question_index, prizes);
				gm.present_frame();
			}
			safe_stop(lock_sfx);
		}
	}
	if (anticipation_enabled) {
		sound heartbeat_sfx;
		if (load_sound(heartbeat_sfx, "heartbeat.mp3")) {
			heartbeat_sfx.volume = 0; 
			heartbeat_sfx.play();
			timer wait_timer;
			while (wait_timer.elapsed < 4000) {
				wait(5);
				touch_manager.monitor();
				gm.prepare_frame();
				gm.draw_question(q.question, q.options, current_selection);
				gm.draw_prize_ladder(question_index, prizes);
				gm.present_frame();
			}
			safe_stop(heartbeat_sfx);
		}
	}
	bool is_correct = (i == q.correct_index);
	if (is_correct) {
		return true;
	}
	if (double_dip_active) {
		play_sfx("Kbc Galat Jawab.mp3");
		alert("Wrong!", "That is incorrect, but you have Double Dip active! Try one more time.");
		double_dip_active = false;
		// We can't easily disable a button in audio_form once created without recreating the form, 
		// but we can set its state to disabled if audio_form supports it.
		// For now, we'll just continue.
		if (question_index < 10) {
			load_sound(bg_music, "clock-sound.mp3");
			bg_music.volume = 0;
		} else {
			load_sound(bg_music, "gameMusic.mp3");
			bg_music.volume = 0;
		}
		bg_music.play_looped();
		return false; 
	}
	safe_stop(bg_music);
	play_sfx("Kbc Galat Jawab.mp3", true);
	alert("Game Over", "Wrong answer! The correct answer was: " + q.options[q.correct_index] + ". Better luck next time.");
	exit_game_flag = true; 
	return false;
}

bool exit_game_flag = false;

bool play_question(Question@ q, int question_index) {
	exit_game_flag = false;
	safe_stop(bg_music);
	if (question_index < 10) {
		load_sound(bg_music, "clock-sound.mp3");
		bg_music.volume = 0; 
	} else {
		load_sound(bg_music, "gameMusic.mp3");
		bg_music.volume = 0; 
	}
	bg_music.play_looped();
	audio_form f;
	f.create_window("Quizzy", false);
	int q_field = f.create_input_box("Question", q.question, "", 0, true, true);
	int progress_list = f.create_list("Prize Progress");
	for (uint i = 0; i < prizes.length(); i++) {
		string status = "";
		if (int(i) < question_index) status = " - Completed";
		else if (int(i) == question_index) status = " - Current";
		f.add_list_item(progress_list, "Question " + (i + 1) + status + " for ₹" + prizes[i]);
	}
	f.set_list_position(progress_list, question_index);
	int[] option_buttons;
	for (uint i = 0; i < q.options.length(); i++) {
		option_buttons.insert_last(f.create_button(q.options[i]));
	}
	int btn_5050 = -1;
	if (state.lifeline_5050) btn_5050 = f.create_button("Lifeline: 50-50");
	int btn_phone = -1;
	if (state.lifeline_phone) btn_phone = f.create_button("Lifeline: Phone a Friend");
	int btn_audience = -1;
	if (state.lifeline_audience) btn_audience = f.create_button("Lifeline: Ask the Audience");
	int btn_double = -1;
	if (state.lifeline_double_dip) btn_double = f.create_button("Lifeline: Double Dip");
	int btn_expert = -1;
	if (state.lifeline_expert) btn_expert = f.create_button("Lifeline: Ask an Expert");
	int quit_btn = f.create_button("Quit Game", false, true);
	f.focus(q_field);
	bool double_dip_active = false;
	timer t; 
	int last_focus = -1;
	int master_vol = int(config.read_number("master_volume", 100));
	set_sound_master_volume(master_vol == 0 ? -100.0 : 20.0 * log10(float(master_vol) / 100.0));
	while (true) {
		wait(5);
		touch_manager.monitor();
		f.monitor();
		gm.prepare_frame();
		int current_selection = -1;
		int current_focus = f.get_current_focus();
		if (current_focus != last_focus) {
			for (uint i = 0; i < option_buttons.length(); i++) {
				if (current_focus == option_buttons[i]) {
					string prefix = "";
					if (i == 0) prefix = "a: ";
					else if (i == 1) prefix = "b: ";
					else if (i == 2) prefix = "c: ";
					else if (i == 3) prefix = "d: ";
					speak(prefix + q.options[i], true);
					break;
				}
			}
			last_focus = current_focus;
		}
		for (uint i = 0; i < option_buttons.length(); i++) {
			if (current_focus == option_buttons[i]) {
				current_selection = i;
				break;
			}
		}
		gm.draw_question(q.question, q.options, current_selection);
		gm.draw_prize_ladder(question_index, prizes);
		gm.present_frame();
		int shortcut_selection = -1;
		if (key_pressed(KEY_A) && option_buttons.length() > 0) shortcut_selection = 0;
		if (key_pressed(KEY_B) && option_buttons.length() > 1) shortcut_selection = 1;
		if (key_pressed(KEY_C) && option_buttons.length() > 2) shortcut_selection = 2;
		if (key_pressed(KEY_D) && option_buttons.length() > 3) shortcut_selection = 3;
		
		if (shortcut_selection != -1) {
			f.focus(option_buttons[shortcut_selection]);
			// We'll let the next iteration handle the click or we can manually trigger it here.
			// To make it "appear" immediately as requested:
			if (handle_option_selection(q, question_index, shortcut_selection, option_buttons, double_dip_active, current_selection)) {
				return true;
			}
		}

		if (key_pressed(KEY_L)) {
			string ladder = "Prize Ladder: ";
			for (int j = int(prizes.length()) - 1; j >= 0; j--) {
				string marker = "";
				if (j == 4 || j == 9 || j == 15) marker = " - Milestone";
				if (j == question_index) marker = " - CURRENT";
				ladder += "Question " + (j + 1) + ": ₹" + prizes[j] + marker + ". ";
			}
			speak(ladder, false);
		}
		if (key_pressed(KEY_PAGEUP)) {
			master_vol += 5;
			if (master_vol > 100) master_vol = 100;
			float db = (master_vol == 0 ? -100.0 : 20.0 * log10(float(master_vol) / 100.0));
			set_sound_master_volume(db);
			config.write_number("master_volume", master_vol);
			speak("Volume " + master_vol, false);
		}
		if (key_pressed(KEY_PAGEDOWN)) {
			master_vol -= 5;
			if (master_vol < 0) master_vol = 0;
			float db = (master_vol == 0 ? -100.0 : 20.0 * log10(float(master_vol) / 100.0));
			set_sound_master_volume(db);
			config.write_number("master_volume", master_vol);
			speak("Volume " + master_vol, false);
		}
		if (key_pressed(KEY_F5) && !state.blitz_played) {
			blitz_round();
			f.focus(q_field); 
		}
		int time_limit = 0;
		if (question_index < 5) time_limit = 30000;
		else if (question_index < 10) time_limit = 60000;
		if (time_limit > 0 && t.elapsed >= time_limit) {
			safe_stop(bg_music);
			play_sfx("Kbc Galat Jawab.mp3", true); 
			alert("Time Up", "You ran out of time! The correct answer was: " + q.options[q.correct_index]);
			return false;
		}
		for (uint i = 0; i < option_buttons.length(); i++) {
			if (f.is_pressed(option_buttons[i])) {
				if (handle_option_selection(q, question_index, i, option_buttons, double_dip_active, current_selection)) {
					return true;
				}
				if (exit_game_flag) return false;
				continue;
			}
		}
		if (btn_5050 != -1 && f.is_pressed(btn_5050)) {
			state.lifeline_5050 = false;
			state.lifelines_used_count++;
			f.set_state(btn_5050, false, false);
			int removed = 0;
			for (uint i = 0; i < option_buttons.length() && removed < 2; i++) {
				if (int(i) != q.correct_index) {
					f.set_state(option_buttons[i], false, true);
					removed++;
				}
			}
			alert("50-50", "Two incorrect options have been removed.");
		}
		if (btn_phone != -1 && f.is_pressed(btn_phone)) {
			state.lifeline_phone = false;
			state.lifelines_used_count++;
			f.set_state(btn_phone, false, false);
			safe_stop(bg_music);
			t.pause();
			play_sfx("PhoneFriend_10-02-26_16-19-22-264 .mp3", true); 
			alert("Phone a Friend", "Your friend thinks the answer is: " + q.options[q.correct_index]);
			bg_music.play_looped();
			t.resume();
		}
		if (btn_audience != -1 && f.is_pressed(btn_audience)) {
			state.lifeline_audience = false;
			state.lifelines_used_count++;
			f.set_state(btn_audience, false, false);
			safe_stop(bg_music);
			t.pause();
			play_sfx("AskTheAudence_10-02-26_16-02-28-118 .mp3", true);
			show_audience_poll(q);
			bg_music.play_looped();
			t.resume();
		}
		if (btn_double != -1 && f.is_pressed(btn_double)) {
			state.lifeline_double_dip = false;
			state.lifelines_used_count++;
			f.set_state(btn_double, false, false);
			double_dip_active = true;
			alert("Double Dip", "Double Dip active! You can now make two guesses for this question.");
		}
		if (btn_expert != -1 && f.is_pressed(btn_expert)) {
			state.lifeline_expert = false;
			state.lifelines_used_count++;
			f.set_state(btn_expert, false, false);
			alert("Ask an Expert", "The expert says the correct answer is definitely: " + q.options[q.correct_index]);
		}
		if (f.is_pressed(quit_btn)) {
			play_sfx("gameQuit_10-02-26_16-16-54-380.mp3", true);
			safe_stop(bg_music);
			return false;
		}
	}
	safe_stop(bg_music);
	return false;
}

void blitz_round() {
	if (blitz_fetching) {
		speak("Please wait, blitz questions are still loading...", false);
		while (blitz_fetching) {
			wait(5);
			touch_manager.monitor();
			gm.prepare_frame();
			gm.draw_logo();
			gm.present_frame();
		}
	}
	state.blitz_played = true;
	if (!blitz_ready) {
		init_questions(state.current_lang, 0, 20, true);
	}
	blitz_mutex.lock();
	if (blitz_pool.length() == 0) {
		blitz_mutex.unlock();
		alert("Quizzy", "No blitz questions available.");
		return;
	}
	int correct_count = 0;
	timer blitz_timer;
	int time_limit = 120000; 
	safe_stop(bg_music);
	load_sound(bg_music, "clock-sound.mp3");
	bg_music.pitch = 120; 
	bg_music.play_looped();
	for (uint i = 0; i < blitz_pool.length(); i++) {
		if (blitz_timer.elapsed >= time_limit) break;
		Question@ q = blitz_pool[i];
		blitz_mutex.unlock(); 
		audio_form f;
		f.create_window("BLITZ ROUND - Time Left: " + ((time_limit - blitz_timer.elapsed) / 1000) + "s", false);
		f.create_input_box("Question", q.question, "", 0, true, true);
		int[] option_buttons;
		for (uint j = 0; j < q.options.length(); j++) {
			option_buttons.insert_last(f.create_button(q.options[j]));
		}
		f.focus(option_buttons[0]);
		bool answered = false;
		while (blitz_timer.elapsed < time_limit && !answered) {
			wait(5);
			touch_manager.monitor();
			f.monitor();
			gm.prepare_frame();
			int current_selection = -1;
			for (uint j = 0; j < option_buttons.length(); j++) {
				if (f.get_current_focus() == option_buttons[j]) {
					current_selection = j;
					break;
				}
			}
			gm.draw_question(q.question, q.options, current_selection);
			gm.present_frame();
			for (uint j = 0; j < option_buttons.length(); j++) {
				if (f.is_pressed(option_buttons[j])) {
					answered = true;
					if (int(j) == q.correct_index) {
						correct_count++;
						speak("correct", false);
					} else {
						speak("incorrect", false);
					}
					break;
				}
			}
		}
		if (blitz_timer.elapsed >= time_limit) break;
		blitz_mutex.lock(); 
	}
	if (blitz_mutex.try_lock()) blitz_mutex.unlock(); 
	safe_stop(bg_music);
	bg_music.pitch = 100;
	alert("Quizzy", "Blitz Over! You answered " + correct_count + " questions correctly!");
	stats.record_blitz(correct_count);
	menu m;
	m.add_item("Claim Bonus Money (₹" + (correct_count * 25000) + ")", "money");
	m.add_item("Retrieve a Lifeline (Cost: ₹25,000)", "lifeline");
	m.intro_text = "Select your reward.";
	m.click_sound = "item_move.mp3";
	m.select_sound = "click.mp3";
	m.edge_sound = "item_move.mp3";
	m.wrap_sound = "item_move.mp3";
	m.focus_first_item = true;
	while (true) {
		m.wrap = (config.read_string("menu_wrap", "false") == "true");
		wait(5);
		touch_manager.monitor();
		gm.prepare_frame();
		gm.draw_menu(m);
		gm.present_frame();
		if (!m.monitor()) {
			string choice = m.selected_item_id;
			if (choice == "money") {
				state.bonus_money += (correct_count * 25000);
				speak("Bonus money added!", false);
				break;
			} else if (choice == "lifeline") {
				state.bonus_money += (correct_count * 25000); 
				retrieve_lifeline_menu();
				break;
			} else {
				state.bonus_money += (correct_count * 25000);
				break;
			}
		}
	}
}

void retrieve_lifeline_menu() {
	if (state.bonus_money < 25000) {
		alert("Quizzy", "You do not have enough bonus money (₹25,000 required) to retrieve a lifeline.");
		return;
	}
	menu m;
	if (!state.lifeline_5050) m.add_item("50-50", "5050");
	if (!state.lifeline_phone) m.add_item("Phone a Friend", "phone");
	if (!state.lifeline_audience) m.add_item("Ask the Audience", "audience");
	if (!state.lifeline_double_dip) m.add_item("Double Dip", "double");
	if (!state.lifeline_expert) m.add_item("Ask an Expert", "expert");
	if (m.get_item_count() == 0) {
		alert("Quizzy", "All lifelines are already available.");
		return;
	}
	m.intro_text = "Select a lifeline to retrieve for ₹25,000. Current Bonus: ₹" + state.bonus_money;
	m.click_sound = "item_move.mp3";
	m.select_sound = "click.mp3";
	m.edge_sound = "item_move.mp3";
	m.wrap_sound = "item_move.mp3";
	m.focus_first_item = true;
	while (true) {
		m.wrap = (config.read_string("menu_wrap", "false") == "true");
		wait(5);
		touch_manager.monitor();
		gm.prepare_frame();
		gm.draw_menu(m);
		gm.present_frame();
		if (!m.monitor()) {
			string choice = m.selected_item_id;
			if (choice == "back" || choice == "") break;
			state.bonus_money -= 25000;
			string name = "";
			if (choice == "5050") { state.lifeline_5050 = true; name = "50-50"; }
			else if (choice == "phone") { state.lifeline_phone = true; name = "Phone a Friend"; }
			else if (choice == "audience") { state.lifeline_audience = true; name = "Ask the Audience"; }
			else if (choice == "double") { state.lifeline_double_dip = true; name = "Double Dip"; }
			else if (choice == "expert") { state.lifeline_expert = true; name = "Ask an Expert"; }
			if (name != "") {
				alert("Quizzy", "The " + name + " lifeline is now available!");
				speak("Lifeline retrieved!", false);
			}
			break;
		}
	}
}

void show_audience_poll(Question@ q) {
	int[] votes(q.options.length());
	int total_votes = 100;
	int correct_votes = random(40, 80); 
	votes[q.correct_index] = correct_votes;
	total_votes -= correct_votes;
	for (uint i = 0; i < votes.length(); i++) {
		if (int(i) == q.correct_index) continue;
		if (total_votes <= 0) {
			votes[i] = 0;
			continue;
		}
		bool is_last = true;
		for (uint j = i + 1; j < votes.length(); j++) {
			if (int(j) != q.correct_index) {
				is_last = false;
				break;
			}
		}
		if (is_last) {
			votes[i] = total_votes;
		} else {
			int v = random(0, total_votes);
			votes[i] = v;
			total_votes -= v;
		}
	}
	string result_text = "";
	for (uint i = 0; i < q.options.length(); i++) {
		result_text += "Option " + (i + 1) + " (" + q.options[i] + "): " + votes[i] + "%\r\n";
	}
	audio_form f;
	f.create_window("Quizzy", false);
	f.create_input_box("Poll Results", result_text, "", 0, true, true);
	int ok_btn = f.create_button("OK", true, true);
	f.focus(ok_btn);
	while (true) {
		wait(5);
		touch_manager.monitor();
		gm.prepare_frame();
		gm.draw_form(f);
		gm.present_frame();
		f.monitor();
		if (f.is_pressed(ok_btn)) break;
	}
}