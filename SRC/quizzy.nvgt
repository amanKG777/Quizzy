string[] prizes = {"1,000", "2,000", "3,000", "5,000", "10,000", "20,000", "40,000", "80,000", "1,60,000", "3,20,000", "6,40,000", "12,50,000", "25,00,000", "50,00,000", "1,00,00,000", "7,00,00,000"};

void play_sfx(string filename, bool wait_for_completion = false) {
	if (wait_for_completion) {
		sound s;
		if (load_sound(s, filename)) {
			s.volume = 0; 
			s.play();
			while (s.playing) {
				wait(5);
				touch_manager.monitor();
				if (gm.initialized) {
					gm.prepare_frame();
					gm.draw_logo();
					gm.present_frame();
				}
			}
		} else {
			if (@pool == null) return;
			int slot = pool.play_stationary(filename, false);
			if (slot < 0) slot = pool.play_stationary("sounds/" + filename, false);
			if (slot >= 0) {
				pool.update_sound_start_values(slot, 0, 0, 100); 
			}
		}
	} else {
		if (@pool == null) return;
		int slot = pool.play_stationary(filename, false);
		if (slot < 0) slot = pool.play_stationary("sounds/" + filename, false);
		if (slot >= 0) {
			pool.update_sound_start_values(slot, 0, 0, 100); 
		}
	}
}

bool load_sound(sound& s, string filename) {
	if (s.load(filename)) return true;
	if (s.load("sounds/" + filename)) return true;
	if (s.load("SRC/sounds/" + filename)) return true;
	return false;
}

void apply_orientation(string orient) {
	string value = "";
	if (orient == "Landscape") value = "LandscapeLeft LandscapeRight";
	else if (orient == "Portrait") value = "Portrait PortraitUpsideDown";
	sdl_set_hint("SDL_HINT_ORIENTATIONS", value);
}

void main() {
	config.setup("Boostof Studios", "Quizzy", false);
	apply_orientation(config.read_string("orientation", "Auto"));
	dictionary m;
	m.set("double_tap1f", int[] = {KEY_RETURN, KEY_SPACE});
	m.set("double_tap2f", KEY_ESCAPE);
	m.set("swipe_up1f", KEY_UP);
	m.set("swipe_down1f", KEY_DOWN);
	m.set("swipe_left1f", int[] = {KEY_LSHIFT, KEY_TAB});
	m.set("swipe_right1f", KEY_TAB);
	m.set("swipe_left2f", KEY_LEFT);
	m.set("swipe_right2f", KEY_RIGHT);
	m.set("swipe_up2f", KEY_PAGEUP);
	m.set("swipe_down2f", KEY_PAGEDOWN);
	@touch_keys = touch_keyboard_interface(touch_manager, m);
	touch_manager.add_touch_interface(touch_keys);
	int master_vol = int(config.read_number("master_volume", 100));
	set_sound_master_volume(master_vol == 0 ? -100.0 : 20.0 * log10(float(master_vol) / 100.0));
	menu_music_enabled = (config.read_string("menu_music_enabled", "true") == "true");
	anticipation_enabled = (config.read_string("anticipation_enabled", "true") == "true");
	option_locking_sound_enabled = (config.read_string("option_locking_sound_enabled", "true") == "true");
	manual_next_question = (config.read_string("manual_next_question", "false") == "true");
	if (game_pack.open("soundsd.dat") || game_pack.open("SRC/soundsd.dat") || game_pack.open("sounds.dat") || game_pack.open("SRC/sounds.dat")) {
		@sound_default_pack = @game_pack;
	}
	string play_intro = config.read_string("play_startup_sound", "true");
	show_window("Quizzy");
	gm.setup();
	gm.enabled = (config.read_string("visuals_enabled", "true") == "true");
	gm.high_contrast = (config.read_string("high_contrast", "false") == "true");
	gm.update_font(config.read_string("font_name", "arial"));
	if (config.read_string("update_on_startup", "true") == "true") {
		check_for_updates(true);
	}
	if (play_intro == "true") {
		sound intro;
		if (intro.load("kbc_intro_sfx.mp3") || intro.load("sounds/kbc_intro_sfx.mp3", null) || intro.load("SRC/sounds/kbc_intro_sfx.mp3", null)) {
			intro.volume = 0;
			intro.play();
			timer intro_timer;
			while (intro_timer.elapsed < 22000) {
				wait(5);
				touch_manager.monitor();
				gm.draw_logo();
				gm.present_frame();
				if (key_pressed(KEY_RETURN)) {
					intro.stop();
					break;
				}
			}
		}
	}
	main_menu();
}

void load_menu_music() {
	if (!menu_music_enabled) return;
	safe_stop(bg_music);
	if (!load_sound(bg_music, "MenuMusic.mp3") && !load_sound(bg_music, "menuMusic.mp3")) return;
	bg_music.volume = 0;
	bg_music.play_looped();
}

string select_language() {
	menu m;
	m.add_item("English", "en");
	m.add_item("Hindi", "hi");
	m.add_item("Back", "back");
	m.intro_text = "Select your preferred language.";
	m.click_sound = "item_move.mp3";
	m.select_sound = "click.mp3";
	m.edge_sound = "item_move.mp3";
	m.wrap_sound = "item_move.mp3";
	m.focus_first_item = true;
	m.wrap = (config.read_string("menu_wrap", "false") == "true");
	string lang = "en";
	while (true) {
		wait(5);
		touch_manager.monitor();
		gm.prepare_frame();
		gm.draw_menu(m);
		gm.present_frame();
		if (!m.monitor()) {
			lang = m.selected_item_id;
			if (lang == "" || lang == "back") return "back";
			break;
		}
	}
	return lang;
}

