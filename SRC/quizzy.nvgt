}

string select_custom_pack() {
	string path = get_custom_questions_path();
	string filename = open_file_dialog("Question Packs:json", "");
	return filename;
}

string format_currency(int amount) {
	string s = "" + amount;
	string res = "";
	if (s.length() <= 3) res = s;
	else {
		res = s.substr(s.length() - 3);
		s = s.substr(0, s.length() - 3);
		while (s.length() > 2) {
			res = s.substr(s.length() - 2) + "," + res;
			s = s.substr(0, s.length() - 2);
		}
		if (s.length() > 0) res = s + "," + res;
	}
	
	string unit = " Rupees";
	if (app.currency == "USD") unit = " Dollars";
	else if (app.currency == "GBP") unit = " Pounds";
	return res + unit;
}

void game_loop() {
	load_menu_music();
	blitz_ready = false;
	blitz_fetching = false;
	blitz_pool.resize(0);
	for (uint i = 0; i < questions.length(); i++) {
		state.current_question_index = i;
		if (!play_question(questions[i], i)) {
			int current_prize = (i > 0) ? prize_values[i-1] : 0;
			stats.record_game(current_prize, state.bonus_money, i, state.lifelines_used_count);
			return;
		}
		if (!state.blitz_played && !blitz_fetching && !blitz_ready && (i >= 6 || state.lifelines_used_count >= 2)) {
			@blitz_fetch_handle = async<void>(init_questions_bg, state.current_lang, 0, 20, true);
		}
		if (!state.blitz_played && (i == 9 || state.lifelines_used_count >= 4)) {
			string reason = (i == 9) ? "You have reached Question 10." : "You have used 4 or more lifelines.";
			if (ask_yes_no("Quizzy", reason + " Would you like to take the blitz mode? If you don't take it now, you can press F5 while playing the game to take it later when you need it.") == 1) {
				blitz_round();
			}
		}
		if (i < 8) {
			play_sfx("sahiJawab_10-02-26_16-31-59-720.mp3", true);
		} else {
			play_sfx("SahiJawab2_15-02-26_15-12-00-471.mp3", true);
		}
		if (app.manual_next_question && i < questions.length() - 1) {
			speak("Correct answer. Press enter to continue to the next question.", false);
			while (!key_pressed(KEY_RETURN)) {
				wait(0);
				app.touch.monitor();
				gm.prepare_frame();
				gm.draw_logo();
				gm.present_frame();
			}
		}
		if (i < questions.length() - 1) {
			if (state.current_lang == "hi") {
				speak("प्रश्न " + (i + 2), false);
			} else if (state.current_lang == "fr") {
				speak("Question " + (i + 2), false);
			} else {
				speak("Question " + (i + 2), false);
			}
		} else {
			if (state.current_lang == "hi") {
				speak("सही जवाब।", false);
			} else if (state.current_lang == "fr") {
				speak("Bonne réponse.", false);
			} else {
				speak("Correct answer.", false);
			}
		}
	}
	safe_stop(app.bg_music);
	string total_prize_str = prizes[questions.length() - 1];
	int base_prize = prize_values[questions.length() - 1];
	int grand_total = base_prize + state.bonus_money;
	stats.record_game(base_prize, state.bonus_money, questions.length(), state.lifelines_used_count);
	if (state.bonus_money > 0) {
		string msg = "Congratulations! You have won the game!\n\nBase Prize: " + total_prize_str + "\nBonus: " + format_currency(state.bonus_money) + "\nGrand Total: " + format_currency(grand_total) + "!";
		if (state.current_lang == "fr") {
			msg = "Félicitations ! Vous avez gagné la partie !\n\nPrix de base : " + total_prize_str + "\nBonus : " + format_currency(state.bonus_money) + "\nGrand total : " + format_currency(grand_total) + " !";
		} else if (state.current_lang == "hi") {
			msg = "बधाई हो! आपने खेल जीत लिया है!\n\nमूल इनाम: " + total_prize_str + "\nबोनस: " + format_currency(state.bonus_money) + "\nकुल योग: " + format_currency(grand_total) + "!";
		}
		alert("Quizzy", msg);
	} else {
		string msg = "Congratulations! You have won the game and earned " + total_prize_str + "!";
		if (state.current_lang == "fr") {
			msg = "Félicitations ! Vous avez gagné la partie et remporté " + total_prize_str + " !";
		} else if (state.current_lang == "hi") {
			msg = "बधाई हो! आपने खेल जीत लिया है और " + total_prize_str + " कमाए हैं!";
		}
		alert("Quizzy", msg);
	}
}

void safe_stop(sound@ s) {
	if (@s == null) return;
	if (s.active && s.playing) {
		s.stop();
	}
}

bool handle_option_selection(QuizSession@ session, int i, int[]& option_buttons, int& current_selection) {
	if (session.is_option_removed(i)) {
		string msg = "This option has been removed.";
		if (state.current_lang == "fr") msg = "Cette option a été supprimée.";
		else if (state.current_lang == "hi") msg = "यह विकल्प हटा दिया गया है।";
		alert("Quizzy", msg);
		return false;
	}
	play_sfx("click.mp3");
	if (ask_yes_no("Quizzy", "Is this your final answer?") != 1) {
		return false; 
	}
	safe_stop(app.bg_music);
	if (app.option_locking_sound_enabled) {
		sound lock_sfx;
		if (load_sound(lock_sfx, "Kbc Option Lock Tune.mp3")) {
			lock_sfx.volume = 0; 
			lock_sfx.play();
			timer wait_timer;
			while (wait_timer.elapsed < 5000) {
				wait(0);
				app.touch.monitor();
				gm.prepare_frame();
				gm.draw_question(session.current_question.question, session.current_question.options, current_selection);
				gm.draw_prize_ladder(session.question_index, prizes);
				gm.present_frame();
			}
			safe_stop(lock_sfx);
		}
	}
	if (app.anticipation_enabled) {
		sound heartbeat_sfx;
		if (load_sound(heartbeat_sfx, "heartbeat.mp3")) {
			heartbeat_sfx.volume = 0; 
			heartbeat_sfx.play();
			timer wait_timer;
			while (wait_timer.elapsed < 4000) {
				wait(0);
				app.touch.monitor();
				gm.prepare_frame();
				gm.draw_question(session.current_question.question, session.current_question.options, current_selection);
				gm.draw_prize_ladder(session.question_index, prizes);
				gm.present_frame();
			}
			safe_stop(heartbeat_sfx);
		}
	}
	bool is_correct = session.is_correct_answer(i);
	if (is_correct) {
		return true;
	}
	if (session.double_dip_active) {
		play_sfx("Kbc Galat Jawab.mp3");
		alert("Wrong!", "That is incorrect, but you have Double Dip active! Try one more time.");
		session.double_dip_active = false;
		if (session.question_index < 10) {
			load_sound(app.bg_music, "clock-sound.mp3");
			app.bg_music.volume = 0;
		} else {
			load_sound(app.bg_music, "gameMusic.mp3");
			app.bg_music.volume = 0;
		}
		app.bg_music.play_looped();
		return false; 
	}
	safe_stop(app.bg_music);
	play_sfx("Kbc Galat Jawab.mp3", true);
	alert("Game Over", "Wrong answer! The correct answer was: " + session.current_question.options[session.current_question.correct_index] + ". Better luck next time.");
	exit_game_flag = true; 
	return false;
}

bool exit_game_flag = false;

bool play_question(Question@ q, int question_index) {
	PlayQuestionScene scene;
	scene.init(q, question_index);
	return scene.run();
}

void blitz_round() {
	if (blitz_fetching) {
		speak("Please wait, blitz questions are still loading...", false);
		while (blitz_fetching) {
			wait(0);
			app.touch.monitor();
			gm.prepare_frame();
			gm.draw_logo();
			gm.present_frame();
		}
	}
	state.blitz_played = true;
	if (!blitz_ready) {
		init_questions(state.current_lang, 0, 20, true);
	}
	blitz_mutex.lock();
	if (blitz_pool.length() == 0) {
		blitz_mutex.unlock();
		alert("Quizzy", "No blitz questions available.");
		return;
	}
	int correct_count = 0;
	timer blitz_timer;
	int time_limit = 120000; 
	safe_stop(app.bg_music);
	load_sound(app.bg_music, "clock-sound.mp3");
	app.bg_music.pitch = 120; 
	app.bg_music.play_looped();
	for (uint i = 0; i < blitz_pool.length(); i++) {
		if (blitz_timer.elapsed >= time_limit) break;
		Question@ q = blitz_pool[i];
		blitz_mutex.unlock();
		audio_form f;
		f.create_window("BLITZ ROUND - Time Left: " + ((time_limit - blitz_timer.elapsed) / 1000) + "s", false);
		f.create_input_box("Question", q.question, "", 0, true, true);
		int[] option_buttons;
		for (uint j = 0; j < q.options.length(); j++) {
			option_buttons.insert_last(f.create_button(q.options[j]));
		}
		f.focus(option_buttons[0]);
		bool answered = false;
		while (blitz_timer.elapsed < time_limit && !answered) {
			wait(0);
			if (!va.listening) {
				app.touch.monitor();
				f.monitor();
			}
			for (uint j = 0; j < option_buttons.length(); j++) {
				if (f.is_pressed(option_buttons[j])) {
					answered = true;
					if (int(j) == q.correct_index) {
						correct_count++;
						speak("correct", false);
					} else {
						speak("incorrect", false);
					}
					break;
				}
			}
			if (answered) break;
			int current_selection = -1;
			for (uint j = 0; j < option_buttons.length(); j++) {
				if (f.get_current_focus() == option_buttons[j]) {
					current_selection = j;
					break;
				}
			}
			gm.prepare_frame();
			gm.draw_question(q.question, q.options, current_selection);
			gm.present_frame();
		}
		if (blitz_timer.elapsed >= time_limit) break;
		blitz_mutex.lock(); 
	}
	if (blitz_mutex.try_lock()) blitz_mutex.unlock(); 
	safe_stop(app.bg_music);
	app.bg_music.pitch = 100;
	alert("Quizzy", "Blitz Over! You answered " + correct_count + " questions correctly!");
	stats.record_blitz(correct_count);
	menu m;
	createDefaultMenu(m);
	int bonus_amount = correct_count * (app.currency == "INR" ? 25000 : 2500); 
	int retrieval_cost = (app.currency == "INR" ? 25000 : 2500);
	m.add_item("Claim Bonus Money (" + format_currency(bonus_amount) + ")", "money");
	m.add_item("Retrieve a Lifeline (Cost: " + format_currency(retrieval_cost) + ")", "lifeline");
	m.intro_text = "Select your reward.";
	va.clear_commands();
	va.add_command("claim bonus money");
	va.add_command("claim bonus");
	va.add_command("money");
	va.add_command("retrieve a lifeline");
	va.add_command("lifeline");
	va.start();
	while (true) {
		m.wrap = (app.config.read_string("menu_wrap", "false") == "true");
		wait(0);
		string v_cmd = va.get_command_non_blocking();
		string v_cmd_choice = "";
		if (v_cmd != "") {
			if (v_cmd == "claim bonus money" || v_cmd == "claim bonus" || v_cmd == "money") v_cmd_choice = "money";
			else if (v_cmd == "retrieve a lifeline" || v_cmd == "lifeline") v_cmd_choice = "lifeline";
		}
		bool menu_selected = false;
		if (!va.listening) {
			app.touch.monitor();
			menu_selected = !m.monitor();
		}
		if (v_cmd_choice != "") menu_selected = true;
		if (menu_selected) {
			string choice = (v_cmd_choice != "") ? v_cmd_choice : m.selected_item_id;
			if (choice == "money") {
				state.bonus_money += bonus_amount;
				speak("Bonus money added!", false);
				break;
			} else if (choice == "lifeline") {
				state.bonus_money += bonus_amount; 
				retrieve_lifeline_menu();
				break;
			} else {
				state.bonus_money += bonus_amount;
				break;
			}
		}
		gm.prepare_frame();
		gm.draw_menu(m);
		gm.present_frame();
	}
}

void retrieve_lifeline_menu() {
	int cost = (app.currency == "INR" ? 25000 : 2500);
	if (state.bonus_money < cost) {
		alert("Quizzy", "You do not have enough bonus money (" + format_currency(cost) + " required) to retrieve a lifeline.");
		return;
	}
	menu m;
	createDefaultMenu(m);
	va.clear_commands();
	if (!state.lifeline_5050) { m.add_item("50-50", "5050"); va.add_command("50 50"); }
	if (!state.lifeline_phone) { m.add_item("Phone a Friend", "phone"); va.add_command("phone a friend"); }
	if (!state.lifeline_audience) { m.add_item("Ask the Audience", "audience"); va.add_command("ask the audience"); }
	if (!state.lifeline_double_dip) { m.add_item("Double Dip", "double"); va.add_command("double dip"); }
	if (!state.lifeline_expert) { m.add_item("Ask an Expert", "expert"); va.add_command("ask an expert"); }
	if (m.get_item_count() == 0) {
		alert("Quizzy", "All lifelines are already available.");
		return;
	}
	m.intro_text = "Select a lifeline to retrieve for " + format_currency(cost) + ". Current Bonus: " + format_currency(state.bonus_money);
	va.add_command("back");
	va.start();
	while (true) {
		m.wrap = (app.config.read_string("menu_wrap", "false") == "true");
		wait(0);
		string v_cmd = va.get_command_non_blocking();
		string v_cmd_choice = "";
		if (v_cmd != "") {
			if (v_cmd == "50 50") v_cmd_choice = "5050";
			else if (v_cmd == "phone a friend") v_cmd_choice = "phone";
			else if (v_cmd == "ask the audience") v_cmd_choice = "audience";
			else if (v_cmd == "double dip") v_cmd_choice = "double";
			else if (v_cmd == "ask an expert") v_cmd_choice = "expert";
			else if (v_cmd == "back") v_cmd_choice = "back";
		}
		bool menu_selected = false;
		if (!va.listening) {
			app.touch.monitor();
			menu_selected = !m.monitor();
		}
		if (v_cmd_choice != "") menu_selected = true;
		if (menu_selected) {
			string choice = (v_cmd_choice != "") ? v_cmd_choice : m.selected_item_id;
			if (choice == "back" || choice == "") break;
			state.bonus_money -= 25000;
			string name = "";
			if (choice == "5050") { state.lifeline_5050 = true; name = "50-50"; }
			else if (choice == "phone") { state.lifeline_phone = true; name = "Phone a Friend"; }
			else if (choice == "audience") { state.lifeline_audience = true; name = "Ask the Audience"; }
			else if (choice == "double") { state.lifeline_double_dip = true; name = "Double Dip"; }
			else if (choice == "expert") { state.lifeline_expert = true; name = "Ask an Expert"; }
			if (name != "") {
				alert("Quizzy", "The " + name + " lifeline is now available!");
				speak("Lifeline retrieved!", false);
			}
			break;
		}
		gm.prepare_frame();
		gm.draw_menu(m);
		gm.present_frame();
	}
}

void show_audience_poll(Question@ q) {
	int[] votes(q.options.length());
	int total_votes = 100;
	int correct_votes = random(40, 80); 
	votes[q.correct_index] = correct_votes;
	total_votes -= correct_votes;
	for (uint i = 0; i < votes.length(); i++) {
		if (int(i) == q.correct_index) continue;
		if (total_votes <= 0) {
			votes[i] = 0;
			continue;
		}
		bool is_last = true;
		for (uint j = i + 1; j < votes.length(); j++) {
			if (int(j) != q.correct_index) {
				is_last = false;
				break;
			}
		}
		if (is_last) {
			votes[i] = total_votes;
		} else {
			int v = random(0, total_votes);
			votes[i] = v;
			total_votes -= v;
		}
	}
	string result_text = "";
	string speak_text = "";
	if (state.current_lang == "hi") speak_text = "दर्शकों के मतदान के परिणाम इस प्रकार हैं: ";
	else if (state.current_lang == "fr") speak_text = "Voici les résultats du vote du public : ";
	else speak_text = "The audience poll results are: ";
	
	for (uint i = 0; i < q.options.length(); i++) {
		string prefix = "";
		if (i == 0) prefix = "a";
		else if (i == 1) prefix = "b";
		else if (i == 2) prefix = "c";
		else if (i == 3) prefix = "d";
		result_text += "Option " + prefix + " (" + q.options[i] + "): " + votes[i] + "%\r\n";
		
		string speak_prefix = "Option " + prefix.upper();
		if (state.current_lang == "hi") speak_prefix = "विकल्प " + prefix.upper();
		else if (state.current_lang == "fr") speak_prefix = "Option " + prefix.upper();
		
		speak_text += speak_prefix + ": " + votes[i] + " percent. ";
	}
	
	if (va.listening) {
		speak(speak_text, false);
		return;
	}
	
	audio_form f;
	f.create_window("Quizzy", false);
	int poll_box = f.create_input_box("Poll Results", result_text, "", 0, true, true);
	int ok_btn = f.create_button("OK", true, true);
	if (va.listening) f.focus_silently(poll_box);
	else f.focus(poll_box);
	va.clear_commands();
	va.add_command("ok");
	va.start();
	while (true) {
		wait(0);
		string v_cmd = va.get_command_non_blocking();
		string v_cmd_choice = "";
		if (v_cmd == "ok") break;
		if (!va.listening) {
			if (!va.listening) {
				app.touch.monitor();
				f.monitor();
			}
		}
		if (f.is_pressed(ok_btn)) break;
		gm.prepare_frame();
		gm.draw_form(f);
		gm.present_frame();
	}
}