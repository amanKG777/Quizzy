void main_menu() {
	load_menu_music();
	menu m;
	createDefaultMenu(m);
	m.add_item("Start Game", "start");
	m.add_item("Download Category for Offline", "download");
	m.add_item("Manage Custom Packs", "manage_custom");
	m.add_item("Statistics", "stats");
	m.add_item("Settings", "settings");
	m.add_item("Credits", "credits");
	m.add_item("Exit", "exit");
	m.intro_text = "Welcome to quizzy! Select an option. Press F1 for Voice Assist Mode.";
	app.input.register_local(KEY_F1, run_voice_assist_mode);
	va.clear_commands();
	va.add_command("start game");
	va.add_command("download category for offline");
	va.add_command("manage custom packs");
	va.add_command("statistics");
	va.add_command("settings");
	va.add_command("credits");
	va.add_command("exit");
	va.start();
	while (true) {
		app.current_state = STATE_MAIN_MENU;
		app.pending_main_menu_return = false;
		m.wrap = (app.config.read_string("menu_wrap", "false") == "true");
		wait(0);
		string v_cmd = va.get_command_non_blocking();
		string v_cmd_choice = "";
		if (v_cmd != "") {
			if (v_cmd == "start game") v_cmd_choice = "start";
			else if (v_cmd == "download category for offline") v_cmd_choice = "download";
			else if (v_cmd == "manage custom packs") v_cmd_choice = "manage_custom";
			else if (v_cmd == "statistics") v_cmd_choice = "stats";
			else if (v_cmd == "settings") v_cmd_choice = "settings";
			else if (v_cmd == "credits") v_cmd_choice = "credits";
			else if (v_cmd == "exit") v_cmd_choice = "exit";
		}
		app.touch.monitor();
		app.input.monitor();
		bool menu_selected = !m.monitor();
		if (v_cmd_choice != "") menu_selected = true;
		if (menu_selected) {
			string choice = (v_cmd_choice != "") ? v_cmd_choice : m.selected_item_id;
			if (choice == "start") {
				while (true) {
					string lang = select_language();
					if (lang == "back" || app.pending_main_menu_return) break;
					int cat_id = select_category();
					if (app.pending_main_menu_return) break;
					if (cat_id == -1) continue; 
					init_questions(lang, cat_id);
					if (questions.length() == 0) {
						alert("Quizzy", "No questions available to start the game.");
					} else {
						state.reset();
						state.current_lang = lang;
						state.category_id = cat_id;
						game_loop();
						load_menu_music();
					}
					if (app.pending_main_menu_return) break;
					break; 
				}
				main_menu_reset(m);
			} else if (choice == "download") {
				string lang = select_language();
				if (lang != "back" && !app.pending_main_menu_return) {
					int cat_id = select_category();
					if (cat_id != -1 && !app.pending_main_menu_return) {
						download_category(cat_id, lang);
					}
				}
				main_menu_reset(m);
			} else if (choice == "manage_custom") {
				manage_custom_packs_menu();
				main_menu_reset(m);
			} else if (choice == "stats") {
				stats.show_stats_menu();
				main_menu_reset(m);
			} else if (choice == "settings") {
				settings_menu();
				main_menu_reset(m);
			} else if (choice == "credits") {
				show_credits();
				main_menu_reset(m);
			} else if (choice == "exit" || choice == "") {
				exit();
			}
		}
		gm.prepare_frame();
		gm.draw_menu(m);
		gm.present_frame();
	}
}

