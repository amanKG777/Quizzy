void settings_menu() {
	string startup_setting = config.read_string("play_startup_sound", "true");
	string wrap_setting = config.read_string("menu_wrap", "false");
	string visuals_setting = config.read_string("visuals_enabled", "true");
	string contrast_setting = config.read_string("high_contrast", "false");
	string menu_music_setting = config.read_string("menu_music_enabled", "true");
	string anticipation_setting = config.read_string("anticipation_enabled", "true");
	string font_setting = config.read_string("font_name", "arial");
	string orientation_setting = config.read_string("orientation", "Auto");
	string source_setting = config.read_string("question_source", "Random");
	string update_on_startup_setting = config.read_string("update_on_startup", "true");
	string locking_setting = config.read_string("option_locking_sound_enabled", "true");
	string next_setting = config.read_string("manual_next_question", "false");
	audio_form f;
	f.create_window("Settings", false, true);
	int chk_startup = f.create_checkbox("Enable Startup Intro", startup_setting == "true");
	int chk_update_startup = f.create_checkbox("Check for updates on startup", update_on_startup_setting == "true");
	int btn_check_now = f.create_button("Check for updates now");
	int chk_wrap = f.create_checkbox("Enable Menu Wrapping", wrap_setting == "true");
	int chk_visuals = f.create_checkbox("Enable Visual Display", visuals_setting == "true");
	int chk_contrast = f.create_checkbox("Enable High Contrast", contrast_setting == "true");
	int chk_music = f.create_checkbox("Enable Menu Music", menu_music_setting == "true");
	int chk_anticipation = f.create_checkbox("Enable Heartbeat", anticipation_setting == "true");
	int chk_locking = f.create_checkbox("Enable option locking sound", locking_setting == "true");
	int chk_next = f.create_checkbox("Press Enter to go to next question", next_setting == "true");
	int list_source = f.create_list("Question Source");
	string[] sources = {"OpenTDB", "TriviaAPI", "Random"};
	string[] source_labels = {"Open Trivia DB", "The Trivia API", "Random (Mixed)"};
	for (uint i = 0; i < sources.length(); i++) {
		f.add_list_item(list_source, source_labels[i]);
		if (sources[i] == source_setting) f.set_list_position(list_source, i);
	}
	int list_orientation = f.create_list("Screen Orientation");
	string[] orientations = {"Auto", "Landscape", "Portrait"};
	for (uint i = 0; i < orientations.length(); i++) {
		f.add_list_item(list_orientation, orientations[i]);
		if (orientations[i] == orientation_setting) f.set_list_position(list_orientation, i);
	}
	int list_font = f.create_list("Font Selection");
	string[] fonts = {"arial", "verdana", "tahoma", "georgia", "times", "comic", "hindi"};
	for (uint i = 0; i < fonts.length(); i++) {
		f.add_list_item(list_font, fonts[i]);
		if (fonts[i] == font_setting) f.set_list_position(list_font, i);
	}
	int btn_save = f.create_button("Save Settings", true);
	int btn_cancel = f.create_button("Cancel", false, true);
	f.focus(chk_startup);
	while (true) {
		wait(5);
		touch_manager.monitor();
		gm.prepare_frame();
		gm.draw_form(f);
		gm.present_frame();
		f.monitor();
		if (f.is_pressed(btn_check_now)) {
			check_for_updates(false);
		}
		if (f.is_pressed(btn_save)) {
			config.write_string("play_startup_sound", f.is_checked(chk_startup) ? "true" : "false");
			config.write_string("update_on_startup", f.is_checked(chk_update_startup) ? "true" : "false");
			config.write_string("menu_wrap", f.is_checked(chk_wrap) ? "true" : "false");
			bool v_enabled = f.is_checked(chk_visuals);
			config.write_string("visuals_enabled", v_enabled ? "true" : "false");
			gm.enabled = v_enabled;
			bool h_contrast = f.is_checked(chk_contrast);
			config.write_string("high_contrast", h_contrast ? "true" : "false");
			gm.high_contrast = h_contrast;
			menu_music_enabled = f.is_checked(chk_music);
			config.write_string("menu_music_enabled", menu_music_enabled ? "true" : "false");
			if (!menu_music_enabled) safe_stop(bg_music);
			else if (!bg_music.playing) {
				load_menu_music();
			}
			anticipation_enabled = f.is_checked(chk_anticipation);
			config.write_string("anticipation_enabled", anticipation_enabled ? "true" : "false");
			option_locking_sound_enabled = f.is_checked(chk_locking);
			config.write_string("option_locking_sound_enabled", option_locking_sound_enabled ? "true" : "false");
			manual_next_question = f.is_checked(chk_next);
			config.write_string("manual_next_question", manual_next_question ? "true" : "false");
			int source_pos = f.get_list_position(list_source);
			if (source_pos >= 0) {
				config.write_string("question_source", sources[source_pos]);
			}
			int orient_pos = f.get_list_position(list_orientation);
			if (orient_pos >= 0) {
				string new_orient = orientations[orient_pos];
				config.write_string("orientation", new_orient);
				apply_orientation(new_orient);
			}
			int font_pos = f.get_list_position(list_font);
			if (font_pos >= 0) {
				string new_font = fonts[font_pos];
				config.write_string("font_name", new_font);
				gm.update_font(new_font);
			}
			speak("Settings saved.", false);
			break;
		}
		if (f.is_pressed(btn_cancel)) {
			break;
		}
	}
}

void select_font_menu() {
	menu m;
	m.add_item("Arial", "arial");
	m.add_item("Verdana", "verdana");
	m.add_item("Tahoma", "tahoma");
	m.add_item("Georgia", "georgia");
	m.add_item("Times New Roman", "times");
	m.add_item("Comic Sans MS", "comic");
	m.add_item("Hindi", "hindi");
	m.add_item("Back", "back");
	m.intro_text = "Select a font.";
	m.click_sound = "item_move.mp3";
	m.select_sound = "click.mp3";
	m.edge_sound = "item_move.mp3";
	m.wrap_sound = "item_move.mp3";
	m.focus_first_item = true;
	m.wrap = (config.read_string("menu_wrap", "false") == "true");
	while (true) {
		wait(5);
		touch_manager.monitor();
		gm.prepare_frame();
		gm.draw_menu(m);
		gm.present_frame();
		if (!m.monitor()) {
			if (m.selected_item_id == "back" || m.selected_item_id == "") return;
			string font_name = m.selected_item_id;
			config.write_string("font_name", font_name);
			gm.update_font(font_name);
			speak("Font changed to " + font_name, false);
			break;
		}
	}
}

void manage_custom_packs_menu() {
	menu m;
	m.add_item("Play Custom Pack", "play");
	m.add_item("Create Custom Pack", "create");
	m.add_item("Back", "back");
	m.intro_text = "Manage Custom Packs. Select an option.";
	m.click_sound = "item_move.mp3";
	m.select_sound = "click.mp3";
	m.edge_sound = "item_move.mp3";
	m.wrap_sound = "item_move.mp3";
	m.focus_first_item = true;
	while (true) {
		m.wrap = (config.read_string("menu_wrap", "false") == "true");
		wait(5);
		touch_manager.monitor();
		gm.prepare_frame();
		gm.draw_menu(m);
		gm.present_frame();
		if (!m.monitor()) {
			string choice = m.selected_item_id;
			if (choice == "play") {
				string filename = select_custom_pack();
				if (filename != "") {
					custom_pack_actions_menu(filename);
				}
			} else if (choice == "create") {
				create_custom_pack_form();
			} else if (choice == "back" || choice == "") {
				break;
			}
			m.reset();
			m.add_item("Play Custom Pack", "play");
			m.add_item("Create Custom Pack", "create");
			m.add_item("Back", "back");
		}
	}
}

void custom_pack_actions_menu(string filename) {
	menu m;
	m.add_item("Play", "play");
	m.add_item("Edit", "edit");
	m.add_item("Delete", "delete");
	m.add_item("Back", "back");
	m.intro_text = "Select an action for the pack: " + filename;
	m.click_sound = "item_move.mp3";
	m.select_sound = "click.mp3";
	m.edge_sound = "item_move.mp3";
	m.wrap_sound = "item_move.mp3";
	m.focus_first_item = true;
	while (true) {
		m.wrap = (config.read_string("menu_wrap", "false") == "true");
		wait(5);
		touch_manager.monitor();
		gm.prepare_frame();
		gm.draw_menu(m);
		gm.present_frame();
		if (!m.monitor()) {
			string choice = m.selected_item_id;
			if (choice == "play") {
				if (load_custom_questions(filename)) {
					state.reset();
					state.current_lang = "en";
					game_loop();
					load_menu_music();
				}
				break;
			} else if (choice == "edit") {
				create_custom_pack_form(filename);
				break;
			} else if (choice == "delete") {
				if (ask_yes_no("Quizzy", "Are you sure you want to delete this pack?") == 1) {
					file_delete(filename);
					alert("Quizzy", "The pack has been deleted.");
					break;
				}
			} else if (choice == "back" || choice == "") {
				break;
			}
		}
	}
}

