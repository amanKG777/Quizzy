#pragma asset "$sounds.dat"
#pragma asset "LOGO.png"
#pragma asset "fonts"
#if windows
#pragma plugin "voice_command"
#endif
#include "menu.nvgt"
#include "form.nvgt"
#include "updater.nvgt"
#include "sound_pool.nvgt"
#include "includes/*.nvgt"
#include "touch.nvgt"
#include "settings.nvgt"
#include "includes/voice_assist.nvgt"

const string GAME_VERSION = "1.2.1";
const string GITHUB_REPO_OWNER = "amanKG777";
const string GITHUB_REPO_NAME = "Quizzy";
updater game_updater(GAME_VERSION, GITHUB_REPO_OWNER, GITHUB_REPO_NAME);

void check_for_updates(bool silent_on_no_update) {
	game_updater.check_for_updates(silent_on_no_update);
}

int ask_yes_no(string title, string text) {
	app.current_dialog_text = text;
	menu m;
	createDefaultMenu(m);
	m.add_item("Yes", "1");
	m.add_item("No", "2");
	m.intro_text = text;
	va.clear_commands();
	va.add_command("yes");
	va.add_command("no");
	va.start();
	while (true) {
		wait(0);
		string v_cmd = va.get_command_non_blocking();
		string v_cmd_choice = "";
		if (v_cmd != "") {
			if (v_cmd == "yes") v_cmd_choice = "1";
			else if (v_cmd == "no") v_cmd_choice = "2";
		}
		bool menu_selected = false;
		if (!va.listening) {
			app.touch.monitor();
			menu_selected = !m.monitor();
		}
		if (v_cmd_choice != "") menu_selected = true;
		if (menu_selected) {
			string choice = (v_cmd_choice != "") ? v_cmd_choice : m.selected_item_id;
			if (choice == "") continue;
			app.current_dialog_text = "";
			return parse_int(choice);
		}
		gm.prepare_frame();
		gm.draw_menu(m);
		gm.present_frame();
	}
	app.current_dialog_text = "";
	return 2;
}

string[] prizes;
int[] prize_values;

void update_prizes() {
	prizes.resize(0);
	prize_values.resize(0);
	string cur = app.currency;
	if (cur == "USD" || cur == "GBP") {
		string unit = (cur == "USD" ? " Dollars" : " Pounds");
		prizes = {"100" + unit, "200" + unit, "300" + unit, "500" + unit, "1,000" + unit, "2,000" + unit, "4,000" + unit, "8,000" + unit, "16,000" + unit, "32,000" + unit, "64,000" + unit, "125,000" + unit, "250,000" + unit, "500,000" + unit, "750,000" + unit, "1,000,000" + unit};
		prize_values = {100, 200, 300, 500, 1000, 2000, 4000, 8000, 16000, 32000, 64000, 125000, 250000, 500000, 750000, 1000000};
	} else {
		// Default to INR
		prizes = {"1,000 Rupees", "2,000 Rupees", "3,000 Rupees", "5,000 Rupees", "10,000 Rupees", "20,000 Rupees", "40,000 Rupees", "80,000 Rupees", "1.6 Lakh Rupees", "3.2 Lakh Rupees", "6.4 Lakh Rupees", "12.5 Lakh Rupees", "25 Lakh Rupees", "50 Lakh Rupees", "1 Crore Rupees", "7 Crore Rupees"};
		prize_values = {1000, 2000, 3000, 5000, 10000, 20000, 40000, 80000, 160000, 320000, 640000, 1250000, 2500000, 5000000, 10000000, 70000000};
	}
}

void play_sfx(string filename, bool wait_for_completion = false) {
	if (wait_for_completion) {
		sound s;
		if (load_sound(s, filename)) {
			s.volume = 0; 
			s.play();
			while (s.playing) {
				wait(0);
				app.touch.monitor();
				if (gm.initialized) {
					gm.prepare_frame();
					gm.draw_logo();
					gm.present_frame();
				}
			}
		} else {
			if (@app.pool == null) return;
			int slot = app.pool.play_stationary(filename, false);
			if (slot < 0) slot = app.pool.play_stationary("sounds/" + filename, false);
			if (slot >= 0) {
				app.pool.update_sound_start_values(slot, 0, 0, 100); 
			}
		}
	} else {
		if (@app.pool == null) return;
		int slot = app.pool.play_stationary(filename, false);
		if (slot < 0) slot = app.pool.play_stationary("sounds/" + filename, false);
		if (slot >= 0) {
			app.pool.update_sound_start_values(slot, 0, 0, 100);
		}
	}
}

bool load_sound(sound& s, string filename) {
	if (s.load(filename)) return true;
	if (s.load("sounds/" + filename)) return true;
	if (s.load("SRC/sounds/" + filename)) return true;
	return false;
}

void apply_orientation(string orient) {
	string value = "";
	if (orient == "Landscape") value = "LandscapeLeft LandscapeRight";
	else if (orient == "Portrait") value = "Portrait PortraitUpsideDown";
	sdl_set_hint("SDL_HINT_ORIENTATIONS", value);
}

void adjust_volume(int delta) {
	int master_vol = int(app.config.read_number("master_volume", 100));
	master_vol += delta;
	if (master_vol > 100) master_vol = 100;
	if (master_vol < 0) master_vol = 0;
	float db = (master_vol == 0 ? -100.0 : 20.0 * log10(float(master_vol) / 100.0));
	set_sound_master_volume(db);
	app.config.write_number("master_volume", master_vol);
	speak("Volume " + master_vol, false);
}

void vol_up() {
	adjust_volume(5);
}

void vol_down() {
	adjust_volume(-5);
}

void main() {
	app.input.register_global(KEY_PAGEUP, vol_up);
	app.input.register_global(KEY_PAGEDOWN, vol_down);
	app.config.setup("Boostof Studios", "Quizzy", false);
	app.currency = app.config.read_string("currency", "INR");
	update_prizes();
	apply_orientation(app.config.read_string("orientation", "Auto"));
	activateTouchControls();
	int master_vol = int(app.config.read_number("master_volume", 100));
	set_sound_master_volume(master_vol == 0 ? -100.0 : 20.0 * log10(float(master_vol) / 100.0));
	app.menu_music_enabled = (app.config.read_string("menu_music_enabled", "true") == "true");
	app.anticipation_enabled = (app.config.read_string("anticipation_enabled", "true") == "true");
	app.option_locking_sound_enabled = (app.config.read_string("option_locking_sound_enabled", "true") == "true");
	app.manual_next_question = (app.config.read_string("manual_next_question", "false") == "true");
	if (app.game_pack.open("soundsd.dat") || app.game_pack.open("SRC/soundsd.dat") || app.game_pack.open("sounds.dat") || app.game_pack.open("SRC/sounds.dat")) {
		@sound_default_pack = @app.game_pack;
	}
	string play_intro = app.config.read_string("play_startup_sound", "true");
	@g_window = show_window("Quizzy", WINDOW_FLAG_FULLSCREEN | WINDOW_FLAG_MAXIMIZED);
	if (@g_window != null) {
		g_window.renderer.set_logical_presentation(800, 600, LOGICAL_PRESENTATION_LETTERBOX);
	}
	gm.setup();
	gm.enabled = (app.config.read_string("visuals_enabled", "true") == "true");
	gm.high_contrast = (app.config.read_string("high_contrast", "false") == "true");
	gm.update_font(app.config.read_string("font_name", "arial"));
	if (app.config.read_string("update_on_startup", "true") == "true") {
		check_for_updates(true);
	}
	if (play_intro == "true") {
		sound intro;
		if (intro.load("kbc_intro_sfx.mp3") || intro.load("sounds/kbc_intro_sfx.mp3", null) || intro.load("SRC/sounds/kbc_intro_sfx.mp3", null)) {
			intro.volume = 0;
			intro.play();
			timer intro_timer;
			while (intro_timer.elapsed < 22000) {
				wait(0);
				app.touch.monitor();
				if (key_pressed(KEY_RETURN)) {
					intro.stop();
					break;
				}
				gm.prepare_frame();
				gm.draw_logo();
				gm.present_frame();
			}
		}
	}
	main_menu();
}

void load_menu_music() {
	if (!app.menu_music_enabled) return;
	safe_stop(app.bg_music);
	if (!load_sound(app.bg_music, "MenuMusic.mp3") && !load_sound(app.bg_music, "menuMusic.mp3")) return;
	app.bg_music.volume = 0;
	app.bg_music.play_looped();
}

string select_language() {
	while (true) {
		app.current_state = STATE_LANGUAGE_SELECTION;
		menu m;
		createDefaultMenu(m);
		m.add_item("English", "en");
		m.add_item("Hindi", "hi");
		m.add_item("French", "fr");
		m.add_item("Back", "back");
		m.intro_text = "Select your preferred language. Press F1 for Voice Assist.";
		app.input.register_local(KEY_F1, run_voice_assist_mode);
		string lang = "en";
		va.clear_commands();
		va.add_command("english");
		va.add_command("hindi");
		va.add_command("french");
		va.add_command("back");
		va.start();
		while (true) {
			wait(0);
			string v_cmd = va.get_command_non_blocking();
		string v_cmd_choice = "";
			if (v_cmd != "") {
				if (v_cmd == "english") { v_cmd_choice = "en"; }
				else if (v_cmd == "hindi") { v_cmd_choice = "hi"; }
				else if (v_cmd == "french") { v_cmd_choice = "fr"; }
				else if (v_cmd == "back") { v_cmd_choice = "back"; }
			}
			bool menu_selected = false;
			if (!va.listening) {
				app.touch.monitor();
				menu_selected = !m.monitor();
			}
			if (v_cmd_choice != "") menu_selected = true;
			if (menu_selected) {
				lang = (v_cmd_choice != "") ? v_cmd_choice : m.selected_item_id;
				if (lang == "" || lang == "back") return "back";
				return lang;
			}
			gm.prepare_frame();
			gm.draw_menu(m);
			gm.present_frame();
		}
	}
	return "back";
}

