const string GAME_VERSION = "1.1.9";
const string GITHUB_REPO_OWNER = "amanKG777";
const string GITHUB_REPO_NAME = "Quizzy";

updater game_updater(GAME_VERSION, GITHUB_REPO_OWNER, GITHUB_REPO_NAME);

void check_for_updates(bool silent_on_no_update) {
	game_updater.check_for_updates(silent_on_no_update);
}

#include "graphics_manager.nvgt"
#include "touch.nvgt"
#include "settings.nvgt"

touch_gesture_manager touch_manager;
touch_keyboard_interface@ touch_keys;

bool menu_music_enabled = true;
bool anticipation_enabled = true;
bool option_locking_sound_enabled = true;
bool manual_next_question = false;

pack_file game_pack;
sound bg_music;
sound_pool pool;
tts_voice voice;
settings config;

int ask_yes_no(string title, string text) {
	menu m;
	m.add_item("Yes", "1");
	m.add_item("No", "2");
	m.intro_text = text;
	m.click_sound = "item_move.mp3";
	m.select_sound = "click.mp3";
	m.edge_sound = "item_move.mp3";
	m.wrap_sound = "item_move.mp3";
	m.focus_first_item = true;
	m.wrap = (config.read_string("menu_wrap", "false") == "true");
	while (true) {
		wait(5);
		touch_manager.monitor();
		gm.prepare_frame();
		gm.draw_menu(m);
		gm.present_frame();
		if (!m.monitor()) {
			if (m.selected_item_id == "") continue;
			return parse_int(m.selected_item_id);
		}
	}
	return 2;
}

