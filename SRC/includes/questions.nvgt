void init_fallback_questions() {
	questions.insert_last(Question("What is the capital of India?", {"Mumbai", "New Delhi", "Kolkata", "Chennai"}, 1));
	questions.insert_last(Question("Who is known as the Iron Man of India?", {"Mahatma Gandhi", "Jawaharlal Nehru", "Sardar Vallabhbhai Patel", "Subhas Chandra Bose"}, 2));
	questions.insert_last(Question("Which planet is known as the Red Planet?", {"Earth", "Mars", "Jupiter", "Saturn"}, 1));
	questions.insert_last(Question("Which is the largest ocean on Earth?", {"Atlantic Ocean", "Indian Ocean", "Arctic Ocean", "Pacific Ocean"}, 3));
